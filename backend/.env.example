MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net
MONGODB_DB_NAME=research_pilot
OPENAI_API_KEY=sk-...
CHAT_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
PDF_STORAGE_DIR=./data/pdfs
CHUNK_TOKENS=700
CHUNK_OVERLAP_TOKENS=100
TOP_K_PER_PAPER=5
FULL_TEXT_FALLBACK_TOKEN_THRESHOLD=6000
FULL_TEXT_FALLBACK_MAX_PAPERS=3
CORS_ORIGINS=http://localhost:5173
# Optional — a free Semantic Scholar API key raises the request rate limit for Deep
# Research/AI Search's provider search. Unset falls back to unauthenticated calls.
SEMANTIC_SCHOLAR_API_KEY=
# Secret used to sign auth JWTs — generate a real random value for any non-local deployment
# (e.g. `python -c "import secrets; print(secrets.token_hex(32))"`). The code falls back to an
# insecure default if unset, which is fine for local dev only.
SECRET_KEY=
